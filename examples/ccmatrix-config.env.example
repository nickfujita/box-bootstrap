# box-bootstrap runtime environment (EXAMPLE — contains NO real secrets)
#
# Copy this file somewhere private, fill in the real values, then source it
# right before running install.sh:
#
#     cp examples/ccmatrix-config.env.example ~/bootstrap.env
#     chmod 600 ~/bootstrap.env
#     $EDITOR ~/bootstrap.env
#     set -a; . ~/bootstrap.env; set +a
#     ./install.sh
#
# install.sh reads everything from the environment — never commit filled-in
# copies of this file.

# ── Personal tailnet (component: tailscale) ──────────────────────────────────
# Tagged auth key minted in the PERSONAL tailnet admin console. Must be a
# reusable/ephemeral key authorized for tag:cloud-dev (see README).
export TS_AUTHKEY="tskey-auth-REPLACE_ME"
# Node name to register in the personal tailnet (usually the box's letter/name).
export BOX_NAME="cloud-dev-x"

# ── Matrix bridge (component: matrix) ────────────────────────────────────────
# Matrix homeserver base URL.
export CCMATRIX_HOMESERVER="https://matrix.example.org"
# The bot/user this box logs in as.
export CCMATRIX_USER_ID="@ccmatrix-x:example.org"
# Access token for CCMATRIX_USER_ID (secret).
export CCMATRIX_ACCESS_TOKEN="syt_REPLACE_ME"
# Your own Matrix user id — the admin allowed to drive the bridge.
export CCMATRIX_ADMIN_USER_ID="@you:example.org"
# Outbound proxy the bridge uses to reach the personal tailnet. Defaults to the
# personal tailscaled's HTTP proxy; leave unset to accept the default.
export CCMATRIX_PROXY_URL="http://127.0.0.1:1055"
# Single-letter suffix identifying this box (e.g. a, b, c). Exported into
# ~/.profile by install.sh. REQUIRED.
export CCMATRIX_VM_LETTER="x"

# ── Claude Code plugins marketplace (component: matrix) ───────────────────────
# PLACEHOLDER: the public plugins repo that ships the Matrix bridge plugin has
# not been named yet. Set this to that repo's marketplace URL/spec once decided.
export PLUGINS_REPO_URL="nickfujita/matrix-bridge-plugin"
